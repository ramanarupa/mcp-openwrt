# OpenWRT Router Configuration
OPENWRT_HOST=192.168.1.1
OPENWRT_PORT=22
OPENWRT_USERNAME=root

# Authentication (use one of the following)
# Option 1: Password authentication
OPENWRT_PASSWORD=your_password_here

# Option 2: SSH key authentication (path to key file)
# OPENWRT_PRIVATE_KEY_FILE=/path/to/your/private/key

# Option 3: SSH key authentication (key content directly)
# OPENWRT_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
