{
  "name": "openwrt-mcp-server",
  "version": "2.0.0",
  "description": "MCP Server for OpenWRT configuration via Claude Code",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "openwrt-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "openwrt",
    "ubus",
    "claude"
  ],
  "author": "Rustam Gaifiev <rgaifiev@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ssh2": "^1.15.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
