# OpenWRT Router Configuration
OPENWRT_HOST=192.168.1.1
OPENWRT_PORT=22
OPENWRT_USERNAME=root

# Authentication (use one of the following)
# Option 1: Password authentication
OPENWRT_PASSWORD=your_password_here

# Option 2: SSH key authentication (uncomment and set path)
# OPENWRT_PRIVATE_KEY=/path/to/your/private/key
